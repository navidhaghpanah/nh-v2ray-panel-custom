[Unit]
Description=nh-v2ray-panel Service
After=network.target
Wants=network.target

[Service]
EnvironmentFile=-/etc/sysconfig/nh-v2ray-panel
Environment="XRAY_VMESS_AEAD_FORCED=false"
Type=simple
WorkingDirectory=/usr/local/nh-v2ray-panel/
ExecStart=/usr/local/nh-v2ray-panel/nh-v2ray-panel
ExecReload=kill -USR1 $MAINPID
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
